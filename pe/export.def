LIBRARY export
EXPORTS
    exported_named @1
    exported_ordinal @2 NONAME
    ; Two names aliasing the same function. Each name gets its own ordinal.
    exported_multi @3
    exported_alias=exported_multi @4
    ; Ordinal @5 is left unused.
    forward_by_name=kernel32.Sleep @6
    forward_by_ordinal=kernel32.#123 @7
